# GarageFlow - Maintenance Requests (REST Client)
# WARNING: clean/reset are destructive operations for local development.

@baseUrl = http://localhost:{{$dotenv API_HTTP_PORT}}
@username = {{$dotenv API_USERNAME}}
@password = {{$dotenv API_PASSWORD}}
@token = {{login.response.body.$.accessToken}}

### Health
###

GET {{baseUrl}}/health
Accept: application/json

###
### Auth - Administrative
###

# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
### Development Database - Migrate
###

POST {{baseUrl}}/dev/database/migrate
Authorization: Bearer {{token}}
Accept: application/json

###
### Development Database - Clean (destructive)
###

POST {{baseUrl}}/dev/database/clean
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{
  "confirm": true
}

###
### Development Database - Reset (destructive)
###

POST {{baseUrl}}/dev/database/reset
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{
  "confirm": true
}

###
### Safety Example (should return 400)
###

POST {{baseUrl}}/dev/database/reset
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{
  "confirm": false
}
