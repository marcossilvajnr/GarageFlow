# GarageFlow - Demo Service Order with Purchase (REST Client)
# Single-file end-to-end demo flow.
# Run requests from top to bottom.

@baseUrl = http://localhost:{{$dotenv API_HTTP_PORT}}
@username = {{$dotenv API_USERNAME}}
@password = {{$dotenv API_PASSWORD}}
@token = {{login.response.body.$.accessToken}}

# Runtime IDs generated along the flow
@supplierId = {{createSupplier.response.body.$.id}}
@partId = {{createPart.response.body.$.id}}
@brakePadPartId = {{createBrakePadPart.response.body.$.id}}
@supplyId = {{createSupply.response.body.$.id}}
@primaryServiceId = {{createPrimaryService.response.body.$.id}}
@diagnosticServiceId = {{createDiagnosticService.response.body.$.id}}
@customerId = {{createCustomer.response.body.$.id}}
@vehicleId = {{createVehicle.response.body.$.id}}
@attendantEmployeeId = {{createAttendant.response.body.$.id}}
@mechanicEmployeeId = {{createMechanic.response.body.$.id}}
@stockistEmployeeId = {{createStockist.response.body.$.id}}
@serviceOrderId = {{createServiceOrder.response.body.$.id}}
@executionOrderId = {{createExecutionOrder.response.body.$.id}}
@diagnosticExecutionOrderId = {{createDiagnosticExecutionOrder.response.body.$.id}}
@separationOrderId = {{createSeparationOrder.response.body.$.id}}
@diagnosticSeparationOrderId = {{createDiagnosticSeparationOrder.response.body.$.id}}
@purchaseOrderId = {{createPurchaseOrder.response.body.$.id}}

###
### 00) Maintenance - Reset DB (destructive)
###

POST {{baseUrl}}/dev/database/reset
Content-Type: application/json
Accept: application/json

{
  "confirm": true
}

###
### 01) Auth + Health
###

# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###

GET {{baseUrl}}/health
Accept: application/json

###
### 02) Base Registrations
###

# @name createSupplier
POST {{baseUrl}}/suppliers/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Centro Automotivo Paulista LTDA",
  "cnpj": "11222333000181",
  "email": "contato@centroautomotivopaulista.com.br",
  "phoneNumber": "11940028922",
  "street": "Avenida Industrial",
  "number": "1000",
  "complement": "Bloco B",
  "neighborhood": "Distrito Industrial",
  "city": "Sao Paulo",
  "state": "SP",
  "zipCode": "04567000"
}

###
# list validation
GET {{baseUrl}}/suppliers?page=1&pageSize=20
Authorization: Bearer {{token}}
Accept: application/json

###

# @name createPart
POST {{baseUrl}}/parts/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Filtro de Oleo",
  "code": "PART-OILFILTER-001",
  "sku": "SKU-OILFILTER-001",
  "unitOfMeasure": "UN",
  "unitPrice": 45.90
}

###

# @name createBrakePadPart
POST {{baseUrl}}/parts/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Pastilha de Freio Dianteira",
  "code": "PART-BRAKEPAD-001",
  "sku": "SKU-BRAKEPAD-001",
  "unitOfMeasure": "UN",
  "unitPrice": 89.90
}

###
# list validation
GET {{baseUrl}}/parts?page=1&pageSize=20
Authorization: Bearer {{token}}
Accept: application/json

###

# @name createSupply
POST {{baseUrl}}/supplies/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Oleo de Motor 5W30",
  "code": "SUP-5W30-001",
  "unitOfMeasure": "L",
  "baseCost": 32.50,
  "preferredSupplierId": "{{supplierId}}"
}

###
# list validation
GET {{baseUrl}}/supplies?page=1&pageSize=20
Authorization: Bearer {{token}}
Accept: application/json

###

# @name createPrimaryService
POST {{baseUrl}}/services/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "code": "SRV-OILCHANGE-001",
  "name": "Troca de Oleo e Filtro",
  "description": "Servico completo de troca de oleo e filtro",
  "basePrice": 220.00,
  "estimatedDurationMinutes": 60
}

###

POST {{baseUrl}}/services/{{primaryServiceId}}/parts
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "partId": "{{partId}}",
  "quantity": 1
}

###

POST {{baseUrl}}/services/{{primaryServiceId}}/supplies
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "supplyId": "{{supplyId}}",
  "quantity": 4
}

###

# @name createDiagnosticService
POST {{baseUrl}}/services/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "code": "SRV-BRAKEPADS-001",
  "name": "Troca de Pastilhas de Freio",
  "description": "Substituicao das 2 pastilhas de freio dianteiro",
  "basePrice": 420.00,
  "estimatedDurationMinutes": 90
}

###

POST {{baseUrl}}/services/{{diagnosticServiceId}}/parts
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "partId": "{{brakePadPartId}}",
  "quantity": 2
}

###
# list validation
GET {{baseUrl}}/services?page=1&pageSize=20
Authorization: Bearer {{token}}
Accept: application/json

###

# @name createCustomer
POST {{baseUrl}}/customers/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Marcos Silva",
  "documentType": 0,
  "document": "12345678909",
  "email": "marcos.silva@email.com",
  "phoneNumber": "11987654321",
  "street": "Rua das Oficinas",
  "number": "145",
  "complement": "Casa",
  "neighborhood": "Centro",
  "city": "Sao Paulo",
  "state": "SP",
  "zipCode": "01010000"
}

###
# list validation
GET {{baseUrl}}/customers?page=1&pageSize=20
Authorization: Bearer {{token}}
Accept: application/json

###

# @name createVehicle
POST {{baseUrl}}/vehicles/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "customerId": "{{customerId}}",
  "licensePlate": "BRA2E19",
  "renavam": "11144477731",
  "make": "Toyota",
  "model": "Corolla",
  "year": 2020,
  "color": "Prata"
}

###
# list validation
GET {{baseUrl}}/vehicles?customerId={{customerId}}&page=1&pageSize=20
Authorization: Bearer {{token}}
Accept: application/json

###

