  "role": 3
}

###
# list validation
GET {{baseUrl}}/employees?page=1&pageSize=20
Authorization: Bearer {{token}}
Accept: application/json

###
### 03) Stock Setup (shortage scenario)
###

POST {{baseUrl}}/stock/entries
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "itemId": "{{partId}}",
  "itemType": 1,
  "quantity": 20,
  "minimumQuantity": 5,
  "reason": "Carga inicial de estoque - peca",
  "referenceId": null
}

###

POST {{baseUrl}}/stock/entries
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "itemId": "{{brakePadPartId}}",
  "itemType": 1,
  "quantity": 40,
  "minimumQuantity": 8,
  "reason": "Carga inicial de estoque - pastilhas (estoque suficiente)",
  "referenceId": null
}

###

POST {{baseUrl}}/stock/entries
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "itemId": "{{supplyId}}",
  "itemType": 2,
  "quantity": 2,
  "minimumQuantity": 5,
  "reason": "Carga inicial de estoque - insumo (baixo para cenario critico)",
  "referenceId": null
}

###
# quick validations
GET {{baseUrl}}/stock/1/{{partId}}
Authorization: Bearer {{token}}
Accept: application/json

###

GET {{baseUrl}}/stock/1/{{brakePadPartId}}
Authorization: Bearer {{token}}
Accept: application/json

###

GET {{baseUrl}}/stock/2/{{supplyId}}
Authorization: Bearer {{token}}
Accept: application/json

###
### 04) Service Order up to quote approval
###

# @name createServiceOrder
POST {{baseUrl}}/service-orders/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "customerId": "{{customerId}}",
  "vehicleId": "{{vehicleId}}",
  "frontDeskEmployeeId": "{{attendantEmployeeId}}"
}

###

POST {{baseUrl}}/service-orders/{{serviceOrderId}}/services
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "serviceId": "{{primaryServiceId}}",
  "actorId": "{{attendantEmployeeId}}"
}

###

POST {{baseUrl}}/service-orders/{{serviceOrderId}}/diagnostic/start
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "mechanicId": "{{mechanicEmployeeId}}"
}

###

# mechanic adds an additional service identified during diagnosis
POST {{baseUrl}}/service-orders/{{serviceOrderId}}/diagnostic/services
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "serviceId": "{{diagnosticServiceId}}"
}

###

POST {{baseUrl}}/service-orders/{{serviceOrderId}}/diagnostic/complete
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description": "Diagnostic completed. Service validated for execution."
}

###

POST {{baseUrl}}/service-orders/{{serviceOrderId}}/diagnostic/consolidate-services
Authorization: Bearer {{token}}

###

POST {{baseUrl}}/service-orders/{{serviceOrderId}}/quote/generate
Authorization: Bearer {{token}}

###

GET {{baseUrl}}/service-orders/{{serviceOrderId}}/quote
Authorization: Bearer {{token}}
Accept: application/json

###

POST {{baseUrl}}/service-orders/{{serviceOrderId}}/quote/accept
Authorization: Bearer {{token}}

###
# list validation
GET {{baseUrl}}/service-orders?page=1&pageSize=20
Authorization: Bearer {{token}}
Accept: application/json

###
### 05) Execution + Separation -> waiting purchase
###

# @name createExecutionOrder
POST {{baseUrl}}/execution-orders/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "serviceOrderId": "{{serviceOrderId}}",
  "serviceId": "{{primaryServiceId}}",
  "mechanicId": "{{mechanicEmployeeId}}"
}

###

# @name createDiagnosticExecutionOrder
POST {{baseUrl}}/execution-orders/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "serviceOrderId": "{{serviceOrderId}}",
  "serviceId": "{{diagnosticServiceId}}",
  "mechanicId": "{{mechanicEmployeeId}}"
}

###

# @name createSeparationOrder
POST {{baseUrl}}/separation-orders/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "executionOrderId": "{{executionOrderId}}",
  "parts": [
    {
      "partId": "{{partId}}",
      "partName": "Filtro de Oleo",
      "quantity": 1
    }
  ],
  "supplies": [
    {
      "supplyId": "{{supplyId}}",
      "supplyName": "Oleo de Motor 5W30",
      "quantity": 4,
      "unit": 1
    }
  ]
}

###
# expected 409 in critical scenario (insufficient stock)
POST {{baseUrl}}/separation-orders/{{separationOrderId}}/reserve
Authorization: Bearer {{token}}

###

# @name createDiagnosticSeparationOrder
POST {{baseUrl}}/separation-orders/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "executionOrderId": "{{diagnosticExecutionOrderId}}",
  "parts": [
    {
      "partId": "{{brakePadPartId}}",
      "partName": "Pastilha de Freio Dianteira",
      "quantity": 2
    }
  ],
  "supplies": []
}

###
# should succeed because brake pad stock is sufficient
POST {{baseUrl}}/separation-orders/{{diagnosticSeparationOrderId}}/reserve
Authorization: Bearer {{token}}

###

POST {{baseUrl}}/separation-orders/{{separationOrderId}}/wait-purchase
Authorization: Bearer {{token}}

###
# list validation
GET {{baseUrl}}/separation-orders?page=1&pageSize=20
Authorization: Bearer {{token}}
Accept: application/json

###
### 06) Purchase Order flow
###

# @name createPurchaseOrder
POST {{baseUrl}}/purchase-orders/
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "separationOrderIds": [
    "{{separationOrderId}}"
  ],
  "items": [
    {
      "itemId": "{{supplyId}}",
      "itemType": 1,
      "itemName": "Oleo de Motor 5W30",
      "quantity": 4,
      "unitPrice": 32.50
    }
  ]
}

###

POST {{baseUrl}}/purchase-orders/{{purchaseOrderId}}/assign-supplier
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "supplierId": "{{supplierId}}",
  "employeeId": "{{stockistEmployeeId}}"
}

###

POST {{baseUrl}}/purchase-orders/{{purchaseOrderId}}/start
Authorization: Bearer {{token}}

###

POST {{baseUrl}}/stock/entries
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "itemId": "{{supplyId}}",
  "itemType": 2,
  "quantity": 10,
  "minimumQuantity": 5,
  "reason": "Entrada de compra - reposicao de insumo para separacao",
  "referenceId": "{{purchaseOrderId}}"
}

###

POST {{baseUrl}}/purchase-orders/{{purchaseOrderId}}/complete
Authorization: Bearer {{token}}

###
# list validations
GET {{baseUrl}}/purchase-orders?page=1&pageSize=20
Authorization: Bearer {{token}}
Accept: application/json

###

GET {{baseUrl}}/separation-orders?page=1&pageSize=20
Authorization: Bearer {{token}}
Accept: application/json

###
### 07) Finalize: separation custody, execution, delivery
###

POST {{baseUrl}}/separation-orders/{{separationOrderId}}/confirm-stockist-withdrawal
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "stockistId": "{{stockistEmployeeId}}"
}

###

POST {{baseUrl}}/separation-orders/{{separationOrderId}}/confirm-mechanic-receipt
Authorization: Bearer {{token}}

###

POST {{baseUrl}}/separation-orders/{{diagnosticSeparationOrderId}}/confirm-stockist-withdrawal
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "stockistId": "{{stockistEmployeeId}}"
}

###

POST {{baseUrl}}/separation-orders/{{diagnosticSeparationOrderId}}/confirm-mechanic-receipt
Authorization: Bearer {{token}}

###

POST {{baseUrl}}/execution-orders/{{executionOrderId}}/start
Authorization: Bearer {{token}}

###

POST {{baseUrl}}/execution-orders/{{executionOrderId}}/complete
Authorization: Bearer {{token}}

###

POST {{baseUrl}}/execution-orders/{{diagnosticExecutionOrderId}}/start
Authorization: Bearer {{token}}

###

POST {{baseUrl}}/execution-orders/{{diagnosticExecutionOrderId}}/complete
Authorization: Bearer {{token}}

###

POST {{baseUrl}}/service-orders/{{serviceOrderId}}/deliver
Authorization: Bearer {{token}}

###
# final list validations
GET {{baseUrl}}/execution-orders?page=1&pageSize=20
Authorization: Bearer {{token}}
Accept: application/json

###

GET {{baseUrl}}/service-orders?page=1&pageSize=20
Authorization: Bearer {{token}}
Accept: application/json
