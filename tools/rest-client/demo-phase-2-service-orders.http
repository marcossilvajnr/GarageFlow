###
### 05) Move Diagnostic Order To InDiagnostic
###

POST {{baseUrl}}/service-orders/{{diagnosticOrderId}}/diagnostic/start
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "mechanicId": "{{mechanicEmployeeId}}"
}

###
### 06) Move Waiting Approval Order To WaitingApproval
###

POST {{baseUrl}}/service-orders/{{waitingApprovalOrderId}}/diagnostic/start
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "mechanicId": "{{mechanicEmployeeId}}"
}

###

POST {{baseUrl}}/service-orders/{{waitingApprovalOrderId}}/diagnostic/services
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "serviceId": "{{secondaryServiceId}}"
}

###

POST {{baseUrl}}/service-orders/{{waitingApprovalOrderId}}/diagnostic/complete
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description": "Diagnostico concluido para demonstracao de status aguardando aprovacao."
}

###

POST {{baseUrl}}/service-orders/{{waitingApprovalOrderId}}/diagnostic/consolidate-services
Authorization: Bearer {{token}}

###

POST {{baseUrl}}/service-orders/{{waitingApprovalOrderId}}/quote/generate
Authorization: Bearer {{token}}

###

### 07) Prepare External Approval Order To WaitingApproval
### The actual external approval is intentionally left for DEMO 11.
###

POST {{baseUrl}}/service-orders/{{approvedOrderId}}/diagnostic/start
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "mechanicId": "{{mechanicEmployeeId}}"
}

###

POST {{baseUrl}}/service-orders/{{approvedOrderId}}/diagnostic/services
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "serviceId": "{{secondaryServiceId}}"
}

###

POST {{baseUrl}}/service-orders/{{approvedOrderId}}/diagnostic/complete
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description": "Diagnostico concluido para demonstracao de aprovacao externa."
}

###

POST {{baseUrl}}/service-orders/{{approvedOrderId}}/diagnostic/consolidate-services
Authorization: Bearer {{token}}

###

POST {{baseUrl}}/service-orders/{{approvedOrderId}}/quote/generate
Authorization: Bearer {{token}}

###

### 08) Move In Execution Order To InExecution
###

POST {{baseUrl}}/service-orders/{{inExecutionOrderId}}/diagnostic/start
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "mechanicId": "{{mechanicEmployeeId}}"
}

###

POST {{baseUrl}}/service-orders/{{inExecutionOrderId}}/diagnostic/services
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "serviceId": "{{secondaryServiceId}}"
}

###

POST {{baseUrl}}/service-orders/{{inExecutionOrderId}}/diagnostic/complete
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description": "Diagnostico concluido para demonstracao de fila em execucao."
}

###

POST {{baseUrl}}/service-orders/{{inExecutionOrderId}}/diagnostic/consolidate-services
Authorization: Bearer {{token}}

###

POST {{baseUrl}}/service-orders/{{inExecutionOrderId}}/quote/generate
Authorization: Bearer {{token}}

###

POST {{baseUrl}}/service-orders/{{inExecutionOrderId}}/quote/accept
Authorization: Bearer {{token}}

###

# @name createInExecutionExecutionOrder
POST {{baseUrl}}/execution-orders/
Authorization: Bearer {{token}}
Content-Type: application/json

{
