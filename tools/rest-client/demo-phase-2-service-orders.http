# GarageFlow - Service Order API Additions Demo (REST Client)
# Focused demo for the API additions: initial services, status read model,
# external quote decision webhook, operational queue ordering, and external
# status updates represented by HTTP calls from REST Client, Swagger or Postman.
#
# Suggested flow:
# 1. Before recording, run SETUP sections 00 to 09 from top to bottom.
# 2. Start recording.
# 3. During the video, run only DEMO sections 10 to 14 from top to bottom.
# 4. In the video, explain that REST Client is the external tool invoking the API.

@baseUrl = http://localhost:{{$dotenv API_HTTP_PORT}}
@username = {{$dotenv API_USERNAME}}
@password = {{$dotenv API_PASSWORD}}
@externalUsername = {{$dotenv EXTERNAL_USERNAME}}
@externalPassword = {{$dotenv EXTERNAL_PASSWORD}}
@token = {{login.response.body.$.accessToken}}
@externalToken = {{externalLogin.response.body.$.accessToken}}

# Runtime IDs
@supplierId = {{createSupplier.response.body.$.id}}
@partId = {{createPart.response.body.$.id}}
@supplyId = {{createSupply.response.body.$.id}}
@primaryServiceId = {{createPrimaryService.response.body.$.id}}
@secondaryServiceId = {{createSecondaryService.response.body.$.id}}
@customerId = {{createCustomer.response.body.$.id}}
@vehicleReceivedId = {{createVehicleReceived.response.body.$.id}}
@vehicleDiagnosticId = {{createVehicleDiagnostic.response.body.$.id}}
@vehicleWaitingApprovalId = {{createVehicleWaitingApproval.response.body.$.id}}
@vehicleApprovedId = {{createVehicleApproved.response.body.$.id}}
@vehicleInExecutionId = {{createVehicleInExecution.response.body.$.id}}
@vehicleDeliveredId = {{createVehicleDelivered.response.body.$.id}}
@vehicleDemoCreatedId = {{createVehicleDemoCreated.response.body.$.id}}
@frontDeskEmployeeId = {{createFrontDesk.response.body.$.id}}
@mechanicEmployeeId = {{createMechanic.response.body.$.id}}
@stockistEmployeeId = {{createStockist.response.body.$.id}}

@receivedOrderId = {{createReceivedOrder.response.body.$.id}}
@diagnosticOrderId = {{createDiagnosticOrder.response.body.$.id}}
@waitingApprovalOrderId = {{createWaitingApprovalOrder.response.body.$.id}}
@approvedOrderId = {{createApprovedOrder.response.body.$.id}}
@inExecutionOrderId = {{createInExecutionOrder.response.body.$.id}}
@deliveredOrderId = {{createDeliveredOrder.response.body.$.id}}
@demoCreatedOrderId = {{demoCreateServiceOrder.response.body.$.id}}
@inExecutionExecutionOrderId = {{createInExecutionExecutionOrder.response.body.$.id}}
@deliveredExecutionOrderId = {{createDeliveredExecutionOrder.response.body.$.id}}
@deliveredSeparationOrderId = {{createDeliveredSeparationOrder.response.body.$.id}}

###
### SETUP - Run Before Recording
###
### This section prepares deterministic data and service orders in the statuses
### needed for the video. It is intentionally verbose so the demo section can
### stay short and focused on the API requirements.
###

###
### 00) Auth
###

# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###

# @name externalLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "{{externalUsername}}",
  "password": "{{externalPassword}}"
}

###
### 01) Reset + Health
###

POST {{baseUrl}}/dev/database/reset
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{
  "confirm": true
}

###

GET {{baseUrl}}/health
Accept: application/json

